# iCloud 認証情報
ICLOUD_APPLE_ID=your_apple_id@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Apple Reminders リスト名
STOCK_LIST_NAME=ストック
FLOW_LIST_NAME=フロー

# Google Calendar OAuth2 クライアント情報
# Google Cloud Console から credentials.json をダウンロードして配置
# 初回認証: python setup_google_auth.py

# タイムゾーン
TIMEZONE=Asia/Tokyo

# サーバー設定
PORT=8080
