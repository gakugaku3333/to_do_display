# Apple Reminders リスト名
STOCK_LIST_NAME=ストック
FLOW_LIST_NAME=フロー

# Google Calendar OAuth2 クライアント情報
# Google Cloud Console から credentials.json をダウンロードして配置
# 初回認証: python setup_google_auth.py husband / wife

# タイムゾーン
TIMEZONE=Asia/Tokyo

# サーバー設定
PORT=8080

# API認証トークン（空欄の場合は認証無効）
API_TOKEN=

# ログレベル (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 学校配布物スキャン機能（Gemini APIキー）
# Google AI Studio (https://aistudio.google.com/) で取得
# 空欄の場合はスキャン機能が動作しない
GEMINI_API_KEY=

# 子供の名前（カンマ区切り）- 学校配布物スキャン機能で使用
CHILDREN=紗奈,和花,舞
